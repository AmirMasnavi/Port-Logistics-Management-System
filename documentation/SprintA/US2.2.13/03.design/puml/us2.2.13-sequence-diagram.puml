@startuml
' US 2.2.13 - Sequence Diagram (Create Qualification)
title US 2.2.13: Create Qualification (SD)

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceParticipant underline

autonumber

actor "Logistics Operator" as Actor
participant ":QualificationsController" as Controller
participant ":IQualificationService" as IService
participant ":QualificationService" as Service
participant "dto:CreateQualificationDto" as Dto
participant ":Qualification" as Aggregate
participant ":QualificationCode" as CodeVO
participant ":QualificationName" as NameVO
participant ":IQualificationRepository" as IRepo
participant ":QualificationRepository" as Repo
participant "respDto:QualificationDto" as RespDto

activate Actor
Actor -> Controller : **POST** /api/qualifications\n(Body: dto)
activate Controller

Controller -> IService : CreateAsync(dto)
activate IService
IService -> Service : CreateAsync(dto)
activate Service

' Value Object Creation & Validation
Service -> CodeVO ** : new QualificationCode(dto.Code)
activate CodeVO
CodeVO --> Service
deactivate CodeVO

Service -> NameVO ** : new QualificationName(dto.Name)
activate NameVO
NameVO --> Service
deactivate NameVO

' Aggregate Creation
Service -> Aggregate ** : new Qualification(codeVO, nameVO, descVO)
activate Aggregate
Aggregate --> Service : qualification
deactivate Aggregate

' Persistence
Service -> IRepo : AddAsync(qualification)
activate IRepo
IRepo -> Repo : AddAsync(qualification)
activate Repo
' EF Core adds to DbContext
Repo --> IRepo
deactivate Repo
IRepo --> Service
deactivate IRepo

' Save changes (explicitly called in this service)
Service -> Repo : SaveChangesAsync()
activate Repo
' EF Core generates SQL INSERT
Repo --> Service
deactivate Repo


' Map Response
Service -> RespDto ** : MapToDto(qualification)
activate RespDto
RespDto --> Service : respDto
deactivate RespDto

Service --> IService : respDto
deactivate Service
IService --> Controller : respDto
deactivate IService

Controller --> Actor : **201 Created**\n(Body: respDto)
deactivate Controller
deactivate Actor
@enduml