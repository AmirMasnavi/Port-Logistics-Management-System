@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle
hide methods

title US2.2.6 - Register and Manage Shipping Agent Representatives - Domain Model

class ShippingAgent {
    orgId
    legalName
    alternativeName
    taxNumber
    address
}

class ShippingAgentRepresentative {
    name
    citizenID
    nationality
    email
    phone
    status   'active/inactive
}

class SystemUser {
    username
    email
    passwordHash
    active
}

class Role {
    name   'Shipping Agent Representative, Port Authority Officer, etc.
}

' === RELATIONSHIPS ===
ShippingAgent "1" - "1..*" ShippingAgentRepresentative : employs >
ShippingAgentRepresentative "1" - "1" SystemUser : is linked to >
SystemUser "1" - "1..*" Role : has >

@enduml
