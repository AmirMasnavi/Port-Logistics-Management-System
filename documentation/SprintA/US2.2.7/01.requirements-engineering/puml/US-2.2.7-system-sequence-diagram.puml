@startuml
' Use template styling (monochrome, etc.)
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

title US2.2.7: Review and Approve/Reject Vessel Visit Notifications - System Sequence Diagram (SSD)

autonumber
actor "Port Authority Officer" as Authority
participant ":System" as System

activate Authority

'--- Review Pending Notifications ---
Authority -> System : requests list of pending Vessel Visit Notifications
activate System
System --> Authority : returns pending notifications (status = Submitted / Approval Pending)
deactivate System

'--- Approve Notification Scenario ---
... Authority selects a pending notification to approve ...
Authority -> System : approves notification with details\n(notificationId, assignedDockId, officerId)
activate System
System --> Authority : validates that assigned dock exists and is available
System --> Authority : records decision log (timestamp, officerId, Approved)
System --> Authority : confirms successful approval and dock assignment
deactivate System

'--- Reject Notification Scenario ---
... Authority selects a pending notification to reject ...
Authority -> System : rejects notification with details\n(notificationId, rejectionReason, officerId)
activate System
System --> Authority : validates provided reason
System --> Authority : records decision log (timestamp, officerId, Rejected)
System --> Authority : confirms successful rejection and notifies shipping agent representative
deactivate System

deactivate Authority
@enduml
