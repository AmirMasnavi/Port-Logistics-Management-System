@startuml
    !theme plain
    autonumber

    actor "Port Authority Officer" as Officer
    participant "User Interface\n(UI)" as UI
    box "Backend System (Sistema AIT)" #LightBlue
        participant "HTTP Request" as HttpRequest
        participant "Route" as Route
        participant "StorageAreaController" as Controller
        participant "CreateStorageAreaDto" as CreateDto
        participant "StorageAreaDto" as Dto
        participant "StorageAreaService" as ServiceImpl
        participant "StorageArea" as DomainEntity
        participant "StorageAreaId" as EntityId
        participant "StorageAreaLocation" as LocationVO
        participant "StorageCapacity" as CapacityVO
        participant "StorageAreaRepository" as RepoImpl
    end box

    Officer -> UI : 1: create or update storage area data
    activate UI

    UI -> HttpRequest : 1.1: POST /api/storagearea OR PUT /api/storagearea/{id} \n (CreateStorageAreaDto)
    activate HttpRequest
    HttpRequest -> Route : 1.2: Match Route
    activate Route
    Route -> Controller : 1.3: Invoke CreateStorageArea / GetStorageAreaById
    activate Controller

    alt Create StorageArea
        Controller -> CreateDto : 1.3.1: Map request body to DTO
        activate CreateDto
        CreateDto --> Controller : 1.3.2: DTO instance
        deactivate CreateDto

        Controller -> ServiceImpl : 1.4: CreateStorageAreaAsync(CreateStorageAreaDto)
        activate ServiceImpl

        ServiceImpl -> LocationVO : 1.4.1: BuildLocation(dto.Location)
        activate LocationVO
        LocationVO --> ServiceImpl : 1.4.2: Location instance
        deactivate LocationVO

        ServiceImpl -> CapacityVO : 1.4.3: new StorageCapacity(dto.Capacity)
        activate CapacityVO
        CapacityVO --> ServiceImpl : 1.4.4: Capacity instance
        deactivate CapacityVO

        ServiceImpl -> DomainEntity : 1.4.5: new StorageArea(location, type, capacity)
        activate DomainEntity
        DomainEntity --> ServiceImpl : 1.4.6: New StorageArea entity created
        deactivate DomainEntity

        ServiceImpl -> RepoImpl : 1.5: AddAsync(StorageArea entity)
        activate RepoImpl
        RepoImpl --> ServiceImpl : 1.6: Entity persisted
        deactivate RepoImpl

        ServiceImpl --> Controller : 1.7: StorageAreaDto (created)
        deactivate ServiceImpl

    else Get StorageArea
        Controller -> ServiceImpl : 1.4: GetByIdAsync(id)
        activate ServiceImpl

        ServiceImpl -> RepoImpl : 1.4.1: GetByIdAsync(StorageAreaId)
        activate RepoImpl
        RepoImpl --> ServiceImpl : 1.4.2: StorageArea entity
        deactivate RepoImpl

        ServiceImpl --> Controller : 1.5: StorageAreaDto (retrieved)
        deactivate ServiceImpl
    end

    Controller --> HttpRequest : 1.8: HTTP 201 Created / 200 OK (StorageAreaDto)
    deactivate Controller
    deactivate Route
    deactivate HttpRequest

    HttpRequest --> UI : 1.9: HTTP Response
    deactivate UI

    UI --> Officer : 1.10: Display confirmation / retrieved data

    @enduml