@startuml
!theme plain
autonumber


box "Backend System (REST API)" #LightBlue
    participant "HTTP Request" as HttpRequest
    participant "Route" as Route
    participant "StaffMembers\nController" as Controller
    participant "IStaffMember\nService" as IService
    participant "StaffMember\nService" as ServiceImpl
    box "Domain / Persistence" #LightGreen
        participant "StaffMember\nAggregate" as Aggregate
        participant "Qualification\nAggregate" as QualAggregate
        participant "IStaffMember\nRepository" as IStaffRepo
        participant "StaffMember\nRepository" as StaffRepoImpl
        participant "IQualification\nRepository" as IQualRepo
        participant "Qualification\nRepository" as QualRepoImpl
    end box
end box

HttpRequest -> Route : 1.1: POST /api/staffMembers
activate HttpRequest
Route -> Controller : 1.2: Invoke CreateStaffMember(dto)
activate Route
Controller -> IService : 1.3: CreateStaffMemberAsync(dto)
activate Controller
activate IService
IService -> ServiceImpl : 1.4: CreateStaffMemberAsync(dto)
activate ServiceImpl

' Example: AddQualification uses Qual Repo
' ServiceImpl -> IQualRepo : GetByCodeAsync(code)
' activate IQualRepo
' IQualRepo -> QualRepoImpl : (database query)
' activate QualRepoImpl
' QualRepoImpl --> IQualRepo
' deactivate QualRepoImpl
' IQualRepo --> ServiceImpl : qualification?
' deactivate IQualRepo

ServiceImpl -> Aggregate : 1.5: new StaffMember(...)
activate Aggregate
Aggregate --> ServiceImpl : 1.6: staffMember
deactivate Aggregate

ServiceImpl -> IStaffRepo : 1.7: AddAsync(staffMember)
activate IStaffRepo
IStaffRepo -> StaffRepoImpl : 1.8: AddAsync(staffMember)
activate StaffRepoImpl
StaffRepoImpl --> IStaffRepo : 1.9: (persisted)
deactivate StaffRepoImpl
IStaffRepo --> ServiceImpl : 1.10: (complete)
deactivate IStaffRepo

ServiceImpl --> IService : 1.11: StaffMemberDto
deactivate ServiceImpl
IService --> Controller : 1.12: StaffMemberDto
deactivate IService
Controller --> HttpRequest : 1.13: HTTP 201 Created
deactivate Controller
deactivate Route
HttpRequest --> : 1.14: HTTP Response
deactivate HttpRequest

@enduml