@startuml
!theme plain
autonumber

box "Backend System (REST API)" #LightBlue
    participant "HTTP Request" as HttpRequest
    participant "Route" as Route
    participant "VesselVisitNotification\nController" as Controller
    participant "VesselVisitNotification\nService" as Service
    box "Domain" #LightGreen
        participant "VesselVisitNotification\nAggregate" as Aggregate
        participant "ContainerCode\nValue Object" as ValueObject
    end box
    participant "VesselVisitNotification\nRepository" as Repository
end box

HttpRequest -> Route : 1.1: POST /api/notifications
activate HttpRequest
Route -> Controller : 1.2: Invoke Create(dto)
activate Route
Controller -> Service : 1.3: CreateAsync(dto)
activate Controller
activate Service

Service -> ValueObject : 1.4: new ContainerCode(code)
activate ValueObject
ValueObject --> Service : 1.5: (validation OK)
deactivate ValueObject

Service -> Aggregate : 1.6: Create(...)
activate Aggregate
Aggregate --> Service : 1.7: (status="InProgress")
deactivate Aggregate

Service -> Repository : 1.8: AddAsync(aggregate)
activate Repository
Repository --> Service : 1.9: (persisted)
deactivate Repository

Service --> Controller : 1.10: VesselVisitNotificationDto
deactivate Service
Controller --> HttpRequest : 1.11: HTTP 201 Created
deactivate Controller
deactivate Route
HttpRequest --> : 1.12: HTTP Response
deactivate HttpRequest

@enduml