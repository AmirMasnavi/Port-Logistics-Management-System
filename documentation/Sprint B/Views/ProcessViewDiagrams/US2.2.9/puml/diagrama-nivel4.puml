@startuml
!theme plain
autonumber

box "Backend System (REST API)" #LightBlue
    participant "HTTP Request" as HttpRequest
    participant "Route" as Route
    participant "VesselVisitNotification\nController" as Controller
    participant "IVesselVisitNotification\nService" as IService
    participant "VesselVisitNotification\nService" as ServiceImpl
    box "Domain / Persistence" #LightGreen
        participant "VesselVisitNotification\nAggregate" as Aggregate
        participant "IVesselVisitNotification\nRepository" as IRepo
        participant "VesselVisitNotification\nRepository" as RepoImpl
    end box
end box

HttpRequest -> Route : 1.1: PUT /api/notifications/{id}
activate HttpRequest
Route -> Controller : 1.2: Invoke Update(id, dto)
activate Route
Controller -> IService : 1.3: UpdateAsync(id, dto)
activate Controller
activate IService
IService -> ServiceImpl : 1.4: UpdateAsync(id, dto)
activate ServiceImpl

ServiceImpl -> IRepo : 1.5: GetByIdAsync(id)
activate IRepo
IRepo -> RepoImpl : 1.6: (database query)
activate RepoImpl
RepoImpl --> IRepo : 1.7: (aggregate)
deactivate RepoImpl
IRepo --> ServiceImpl : 1.8: (aggregate)
deactivate IRepo

ServiceImpl -> Aggregate : 1.9: UpdateDetails(...)
activate Aggregate
Aggregate --> ServiceImpl : 1.10: (business rule checked)
deactivate Aggregate

ServiceImpl -> IRepo : 1.11: UpdateAsync(aggregate)
activate IRepo
IRepo -> RepoImpl : 1.12: (database update)
activate RepoImpl
RepoImpl --> IRepo : 1.13: (complete)
deactivate RepoImpl
IRepo --> ServiceImpl : 1.14: (complete)
deactivate IRepo

ServiceImpl --> IService : 1.15: VesselVisitNotificationDto
deactivate ServiceImpl
IService --> Controller : 1.16: VesselVisitNotificationDto
deactivate IService
Controller --> HttpRequest : 1.17: HTTP 200 OK
deactivate Controller
deactivate Route
HttpRequest --> : 1.18: HTTP Response
deactivate HttpRequest

@enduml