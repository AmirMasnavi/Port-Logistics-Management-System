@startuml
!pragma layout smetana
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle
hide methods
title Domain Model - Port Logistics Management

' ==== CORE ENTITIES ====

class Port {
    name
    location
}

class Dock {
    ID
    name
    lengthCapacity
    numSTSFixedCranes
}

class StorageArea {
    ID
    type   'Yard or Warehouse
    capacity
}

class Vessel {
    IMO
    capacityTEU
    bays
    rows
    tiers
}

class VesselType {
    name
    maxTEU
    length
    draft
    numSTSMax
    operationalConstraints
}

class VesselVisit {
    ETA
    ETD
    cargoVolume
    specialRequirements
    state  'Notified, Approved, Rejected, Rescheduled
}

class CargoManifest {
    ID
    type  'loading/unloading
}

class ContainerManifestEntry {
    bay
    row
    tier
    portPosition
}

class Container {
    ID   'ISO 6346:2022
    sizeTEU
}

class CargoType {
    name
    specialHandling
}

' ==== RESOURCES ====

class LogisticResource {
    operationalWindow
    currentStatus
}

class PhysicalResource {
    type   'STS Crane, Yard Crane, Truck
    operationalCapacity
    setupTime
}

class HumanResource {
    mecanographicNumber
    name
    email
    phone
}

class Qualification {
    name
}

class OperationalTask {
    type   'unloading, moving, loading
    sequence
    status
}

' ==== ORGANIZATIONS & USERS ====

class PortAuthority {
}

class ShippingAgent {
    name
}

class ShippingAgentRepresentative {
    name
    contact
}

class UserAccount {
    ID
    username
}

class Role {
    name   'Port Authority Officer, Shipping Agent Rep, Logistics Operator, Admin
}


' ==== RELATIONSHIPS ====

Port "1" -- "*" Dock : has >
Port "1" -- "*" StorageArea : has >

Dock "1" -- "*" PhysicalResource : includes STS cranes >

Vessel "1" -- "1" VesselType : categorized >
Vessel "1" -- "*" VesselVisit : schedules >

VesselVisit "*" -- "1" Dock : assigned >
VesselVisit "1" -- "*" CargoManifest : includes >

CargoManifest "1" -- "*" ContainerManifestEntry : lists >
ContainerManifestEntry "1" -- "1" Container : refers >
Container "1" -- "1" CargoType : carries >

LogisticResource <|-- PhysicalResource
LogisticResource <|-- HumanResource

PhysicalResource "*" -- "*" HumanResource : requires >
HumanResource "*" -- "*" Qualification : has >

OperationalTask "*" -- "*" LogisticResource : allocates >
OperationalTask "*" -- "1" VesselVisit : belongs >

PortAuthority "1" -- "*" VesselVisit : approves/rejects >
ShippingAgent "1" -- "*" Vessel : represents >
ShippingAgent "1" -- "*" ShippingAgentRepresentative : employs >

UserAccount "1" -- "1" Role : assigned >
UserAccount "1" -- "1" ShippingAgentRepresentative : linked >
UserAccount "1" -- "1" PortAuthority : linked >

@enduml
