@startuml
!theme plain
title Level 2 - Physical View: Vessel Type Management Deployment (Containers)

' === Dispositivo do utilizador ===
node "User Device" as UserDevice {
    component "Web Browser (UI)" as Browser
}

' === Internet ===
cloud "Internet" as Internet

' === Ambiente na Cloud ===
node "Cloud Environment" as CloudEnv #LightSkyBlue {

    ' Servidor responsável pela interface (UI)
    node "Web Server" as UI_Server {
        component "Vessel Type Management UI" as UI_Container <<container (C4)>>
    }

    ' Servidor responsável pela API Backend
    node "Application Server" as App_Server {
        component "Vessel Type API (ASP.NET Core)" as API_Container <<container (C4)>>
    }

    ' Servidor de base de dados
    database "Database Server" as DB_Server {
        storage "PortProject Database" as DB_Storage
    }

    ' Serviço de armazenamento de ficheiros (opcional)
    node "File Storage Service" as FileStorage_Node {
        storage "Filesystem API" as FilesystemAPI
    }
}

' === Conexões ===
UserDevice --> Internet : "HTTP/HTTPS"
Internet --> UI_Server : "HTTP/HTTPS"

UI_Server --> App_Server : "REST API (HTTP/HTTPS)"
App_Server --> DB_Server : "SQL / Entity Framework Core"
App_Server --> FileStorage_Node : "Filesystem access (if used)"

@enduml
