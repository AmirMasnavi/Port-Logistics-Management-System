@startuml
participant Route as route
participant ":VesselTypeController" as controller
participant ":VesselTypeRequest" as requestDto
participant ":VesselTypeService" as service
participant ":VesselTypeRepository" as repo
participant ":UnitOfWork" as uow
database ":VesselTypeDB" as db
participant ":VesselTypeMapper" as mapper
participant ":VesselTypeResponse" as responseDto


' =======================================
' CREATE Vessel Type
' =======================================
activate route
route -> controller: POST /api/vessel-types {JSON body}
activate controller
controller -> requestDto **: new VesselTypeRequest
note right: Desserializa JSON em DTO
controller -> service: CreateAsync(requestDto)
deactivate controller
activate service

service -> repo: AddAsync(VesselType)
activate repo
repo -> uow: CommitAsync()
activate uow
uow -> db: INSERT INTO vessel_types (...)
activate db
db --> uow: success
deactivate db
uow --> repo: committed
deactivate uow
repo --> service: VesselType saved
deactivate repo

service -> mapper: ToResponseDto(VesselType)
activate mapper
mapper -> responseDto **: new VesselTypeResponse
activate responseDto
responseDto --> mapper: VesselTypeResponse
deactivate responseDto
mapper --> service: VesselTypeResponse
deactivate mapper

service --> controller: VesselTypeResponse
activate controller
controller --> route: HTTP 201 Created {VesselTypeResponse}
deactivate controller


' =======================================
' UPDATE Vessel Type
' =======================================
route -> controller: PUT /api/vessel-types/{id} {JSON body}
activate controller
controller -> requestDto **: new VesselTypeRequest
controller -> service: UpdateAsync(id, requestDto)
deactivate controller
activate service

service -> repo: GetByIdAsync(id)
activate repo
repo -> db: SELECT * FROM vessel_types WHERE id = ?
activate db
db --> repo: VesselType or null
deactivate db
repo --> service: VesselType or null
deactivate repo

alt VesselType not found
    service --> controller: NotFoundException
    deactivate service
    activate controller
    controller --> route: HTTP 404 Not Found
    deactivate controller
else VesselType exists
    service -> repo: UpdateAsync(VesselType)
    activate repo
    repo -> uow: CommitAsync()
    activate uow
    uow -> db: UPDATE vessel_types SET ...
    activate db
    db --> uow: success
    deactivate db
    uow --> repo: committed
    deactivate uow
    repo --> service: VesselType updated
    deactivate repo

    service -> mapper: ToResponseDto(VesselType)
    activate mapper
    mapper -> responseDto **: new VesselTypeResponse
    activate responseDto
    responseDto --> mapper: VesselTypeResponse
    deactivate responseDto
    mapper --> service: VesselTypeResponse
    deactivate mapper

    service --> controller: VesselTypeResponse
    activate controller
    controller --> route: HTTP 200 OK {VesselTypeResponse}
    deactivate controller
end


' =======================================
' GET Vessel Type by ID
' =======================================
route -> controller: GET /api/vessel-types/{id}
activate controller
controller -> service: GetByIdAsync(id)
deactivate controller
activate service

service -> repo: GetByIdAsync(id)
activate repo
repo -> db: SELECT * FROM vessel_types WHERE id = ?
activate db
db --> repo: VesselType or null
deactivate db
repo --> service: VesselType or null
deactivate repo

alt VesselType not found
    service --> controller: NotFoundException
    deactivate service
    activate controller
    controller --> route: HTTP 404 Not Found
    deactivate controller
else VesselType found
    service -> mapper: ToResponseDto(VesselType)
    activate mapper
    mapper -> responseDto **: new VesselTypeResponse
    activate responseDto
    responseDto --> mapper: VesselTypeResponse
    deactivate responseDto
    mapper --> service: VesselTypeResponse
    deactivate mapper
    service --> controller: VesselTypeResponse
    activate controller
    controller --> route: HTTP 200 OK {VesselTypeResponse}
    deactivate controller
end


' =======================================
' SEARCH Vessel Types
' =======================================
route -> controller: GET /api/vessel-types/search?query=term
activate controller
controller -> service: SearchAsync(query)
deactivate controller
activate service

service -> repo: SearchAsync(query)
activate repo
repo -> db: SELECT * FROM vessel_types WHERE name LIKE ? OR description LIKE ?
activate db
db --> repo: list of VesselType
deactivate db
repo --> service: list of VesselType
deactivate repo

service -> mapper: ToResponseDtoList(list)
activate mapper
mapper -> responseDto **: new List<VesselTypeResponse>
activate responseDto
responseDto --> mapper: List<VesselTypeResponse>
deactivate responseDto
mapper --> service: List<VesselTypeResponse>
deactivate mapper

service --> controller: List<VesselTypeResponse>
activate controller
controller --> route: HTTP 200 OK [VesselTypeResponse...]
deactivate controller


' =======================================
' DELETE Vessel Type
' =======================================
route -> controller: DELETE /api/vessel-types/{id}
activate controller
controller -> service: DeleteAsync(id)
deactivate controller
activate service

service -> repo: GetByIdAsync(id)
activate repo
repo -> db: SELECT * FROM vessel_types WHERE id = ?
activate db
db --> repo: VesselType or null
deactivate db
repo --> service: VesselType or null
deactivate repo

alt VesselType not found
    service --> controller: NotFoundException
    deactivate service
    activate controller
    controller --> route: HTTP 404 Not Found
    deactivate controller
else VesselType found
    service -> repo: DeleteAsync(VesselType)
    activate repo
    repo -> uow: CommitAsync()
    activate uow
    uow -> db: DELETE FROM vessel_types WHERE id = ?
    activate db
    db --> uow: success
    deactivate db
    uow --> repo: committed
    deactivate uow
    repo --> service: success
    deactivate repo

    service --> controller: NoContent
    activate controller
    controller --> route: HTTP 204 No Content
    deactivate controller
end

@enduml
