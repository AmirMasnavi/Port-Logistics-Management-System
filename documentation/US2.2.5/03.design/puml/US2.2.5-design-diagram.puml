@startuml
' US2.2.5: Register Shipping Agent Organization Sequence Diagram (Design)

title US2.2.5: Register Shipping Agent Organization

actor "Port Authority Officer" as Actor
participant ":RegisterShippingAgentOrgUI" as UI <<Presentation>>
participant ":RegisterShippingAgentOrgController" as Controller <<Application>>
participant ":ShippingAgentOrgService" as Service <<Application>>
participant "AuthzRegistry" as AuthzRegistry <<Framework Facade>>
participant ":AuthorizationService" as AuthService <<Framework Service>>
participant "PersistenceContext" as PersistenceContext <<Framework Facade>>
participant ":ShippingAgentOrganizationRepository" as OrgRepo <<Infrastructure Repository>>
participant "newRepresentative:ShippingAgentRepresentative" as RepEntity <<Domain Entity>>
participant "newOrganization:ShippingAgentOrganization" as OrgEntity <<Domain Aggregate Root>>
database "Database" as DB

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 180
skinparam sequenceParticipant underline

Actor -> UI : Starts organization registration
activate UI

UI -> Controller : create()
activate Controller
' Controller gets AuthService and instantiates Service implicitly
Controller --> UI : instance
deactivate Controller

' --- Stage 1: Create Representative (in memory) ---
UI --> Actor : Requests representative data
Actor -> UI : Provides data (name, citizenId, nationality, email, phone)
UI -> Controller : registerRepresentative(name, citizenId, nationality, email, phone)
activate Controller

Controller -> AuthService : ensureAuthenticatedUserHasAnyOf(ADMIN, PORT_AUTHORITY_OFFICER)
activate AuthService
AuthService --> Controller
deactivate AuthService

' Controller creates the Representative object but DOES NOT save it yet
create RepEntity
Controller -> RepEntity : create(name, citizenId, nationality, email, phone)
Controller --> UI : newRepresentative
deactivate Controller

' --- Stage 2: Register Organization (and persist both) ---
UI --> Actor : Requests organization data (identifier, legalName, altName, address, taxNumber)
Actor -> UI : Provides data
UI -> Controller : registerOrganization(identifier, legalName, altName, address, taxNumber, newRepresentative)
note right of UI : Passes 'newRepresentative' object (transient)
activate Controller

Controller -> AuthService : ensureAuthenticatedUserHasAnyOf(ADMIN, PORT_AUTHORITY_OFFICER)
activate AuthService
AuthService --> Controller
deactivate AuthService

' Controller delegates to the service layer
Controller -> Service : registerOrganizationService(identifier, legalName, altName, address, taxNumber, newRepresentative)
activate Service

Service -> AuthService : ensureAuthenticatedUserHasAnyOf(PORT_AUTHORITY_OFFICER, ADMIN)
activate AuthService
AuthService --> Service
deactivate AuthService

Service -> PersistenceContext : repositories()
activate PersistenceContext
PersistenceContext -> PersistenceContext : get ShippingAgentOrganizationRepository
PersistenceContext --> Service : orgRepo
deactivate PersistenceContext

' --- Business validations (uniqueness) ---
Service -> OrgRepo : existsByIdentifier(identifier)
activate OrgRepo
OrgRepo --> Service : false
deactivate OrgRepo

Service -> OrgRepo : existsByTaxNumber(taxNumber)
activate OrgRepo
OrgRepo --> Service : false
deactivate OrgRepo

' Service creates the Organization aggregate, associating the Representative
create OrgEntity
Service -> OrgEntity : create(identifier, legalName, altName, address, taxNumber, newRepresentative)
note right of Service : Associates 'newRepresentative' with 'newOrganization'

' Service saves the Organization aggregate (cascades Representative)
Service -> OrgRepo : save(newOrganization)
activate OrgRepo

' Repository (e.g., JPA) persists Organization and cascades persistence to Representative
OrgRepo -> DB : INSERT INTO ShippingAgentRepresentative (...) VALUES (...)\nINSERT INTO ShippingAgentOrganization (...) VALUES (...)
activate DB
DB --> OrgRepo : (Success)
deactivate DB

OrgRepo --> Service : savedOrganization
deactivate OrgRepo

Service --> Controller : savedOrganization
deactivate Service

Controller --> UI : savedOrganization
deactivate Controller

UI --> Actor : Displays message "Organization registered successfully"
deactivate UI

@enduml
